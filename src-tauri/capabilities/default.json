{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Ajisai",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "dialog:allow-open",
    "dialog:allow-save"
  ],
  "scope": {
    "fs": [
      "$APPDATA/ajisai-state.json",
      "$APPDATA/ajisai-tables/*.json"
    ]
  }
}
