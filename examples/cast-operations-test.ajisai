# 型変換ワード群のテストケース（STR/NUM/BOOL）
# 文字列リテラルは bare（ベクタで包まない）で cast ワードに渡す。

# ============================================================================
# STR - 任意の型 → String
# ============================================================================

# 数値 → 文字列
[ 42 ] STR

# 分数 → 文字列
[ 1 ] [ 3 ] / STR

# Boolean → 文字列
TRUE STR
FALSE STR

# Nil → 文字列（空文字列）
nil STR

# ベクトル → 文字列（スペース区切り）
[ 1 2 3 ] STR

# ============================================================================
# NUM - String → Number
# ============================================================================

# 整数文字列 → 数値
'42' NUM

# 分数文字列 → 数値
'1/3' NUM

# 小数文字列 → 数値（分数に変換）
'3.14' NUM

# 科学的記数法
'1.5e2' NUM

# 数値として解釈できない文字列 → NIL（absence として伝播）
'not-a-number' NUM

# ============================================================================
# BOOL - String/Number → Boolean
# ============================================================================

# TRUE/FALSE（大文字）
'TRUE' BOOL
'FALSE' BOOL

# true/false（小文字）
'true' BOOL
'false' BOOL

# 混在（大文字小文字無視）
'True' BOOL
'False' BOOL

# TRUE/FALSE 以外の文字列 → NIL
'1' BOOL
'yes' BOOL

# 数値 → Boolean（0 が FALSE、それ以外は TRUE）
1 BOOL
0 BOOL

# ============================================================================
# 組み合わせ例
# ============================================================================

# 数値 → 文字列 → 数値
[ 42 ] STR NUM

# Boolean → 文字列 → Boolean
TRUE STR BOOL

# 文字列から数値に変換してから文字列化
'123' NUM STR

# 数値 → Boolean → 文字列
1 BOOL STR
0 BOOL STR

# 文字列連結の例
[ 10 ] [ 20 ] + STR ' is the sum' CONCAT
