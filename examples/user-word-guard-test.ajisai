# User word behavior regression cases (canonical)

# 1) Basic user word definition and execution
{ [ 1 ] [ 2 ] + } 'ADD12' DEF
ADD12 PRINT
# 期待: [ 3 ]

# 2) User word composed from built-ins
{ [ 1 ] + } 'INC' DEF
[ 41 ] INC PRINT
# 期待: [ 42 ]

# 3) User word can be redefined intentionally
{ [ 2 ] + } 'INC' DEF
[ 40 ] INC PRINT
# 期待: [ 42 ]

# 4) Multi-line $-style COND word
{
  { [ 5 ] > $ [ 'big' ] }
  { IDLE   $ [ 'small' ] } COND
} 'SIZE' DEF
[ 7 ] SIZE PRINT
# 期待: [ 'big' ]
