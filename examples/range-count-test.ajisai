# RANGE のテスト

# ============================================
# RANGE のテスト
# ============================================

# 基本的な範囲生成（[ start end ] の 1 ベクタ形式）
[ 0 5 ] RANGE PRINT
# 期待: [ 0 1 2 3 4 5 ]

# ステップ付き範囲生成（[ start end step ]）
[ 0 10 2 ] RANGE PRINT
# 期待: [ 0 2 4 6 8 10 ]

# 降順範囲
[ 10 0 -2 ] RANGE PRINT
# 期待: [ 10 8 6 4 2 0 ]

# 単一要素
[ 5 5 ] RANGE PRINT
# 期待: [ 5 ]

# ============================================
# RANGE と他のワードとの組み合わせ
# ============================================

# RANGEとMAPの組み合わせ
[ 0 4 ] RANGE { [ 2 ] * } MAP PRINT
# 期待: [ 0 2 4 6 8 ]（各要素を2倍）

# RANGEとFILTERの組み合わせ
[ 0 10 ] RANGE { [ 5 ] > } FILTER PRINT
# 期待: [ 6 7 8 9 10 ]（5より大きい要素）

# ============================================
# 実用的な例
# ============================================

# ベクタの要素数から 0-origin の最終インデックスを計算する
[ 'a' 'b' 'c' 'd' 'e' ] LENGTH [ 1 ] - PRINT
# 期待: [ 4 ]

# その範囲のインデックス列を生成する
[ 0 4 ] RANGE PRINT
# 期待: [ 0 1 2 3 4 ]
