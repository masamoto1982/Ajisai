{
  "name": "ajisai",
  "version": "1.0.0",
  "description": "Ajisai - AI-first, vector-oriented, fractional-dataflow language",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash ./scripts/rebuild-wasm.sh",
    "build:web": "AJISAI_BUILD_TARGET=web vite build",
    "watch": "tsc --watch",
    "dev": "vite",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "deadcode": "ts-prune",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules",
    "tauri": "tauri",
    "tauri:dev": "AJISAI_BUILD_TARGET=tauri tauri dev",
    "tauri:build": "AJISAI_BUILD_TARGET=tauri tauri build",
    "branch:new": "bash ./scripts/create-dated-branch.sh",
    "dev:tauri": "AJISAI_BUILD_TARGET=tauri vite",
    "build:tauri-frontend": "AJISAI_BUILD_TARGET=tauri vite build",
    "check:semantic-firewall": "bash ./scripts/check-semantic-firewall.sh",
    "hooks:install": "git config core.hooksPath .githooks",
    "provenance:attest": "node scripts/generate-source-attestation.mjs",
    "provenance:check": "node scripts/generate-source-attestation.mjs --check",
    "conformance:manifest": "node scripts/generate-conformance-manifest.mjs",
    "word:manifest": "node scripts/generate-word-manifest.mjs",
    "word:manifest:check": "node scripts/generate-word-manifest.mjs --check",
    "check:formalization-coverage": "node scripts/check-formalization-coverage.mjs",
    "generate:skill": "node scripts/generate-skill-md.mjs",
    "check:skill": "node scripts/generate-skill-md.mjs --check",
    "simplify:report": "node scripts/ajisai-simplify-report.mjs",
    "primitive:test-map": "node scripts/generate-primitive-test-map.mjs",
    "vendor:katex": "rm -rf public/vendor/katex && mkdir -p public/vendor/katex/contrib public/vendor/katex/fonts && cp node_modules/katex/dist/katex.min.css node_modules/katex/dist/katex.min.js public/vendor/katex/ && cp node_modules/katex/dist/contrib/auto-render.min.js public/vendor/katex/contrib/ && cp node_modules/katex/dist/fonts/*.woff2 public/vendor/katex/fonts/ && cp node_modules/katex/LICENSE public/vendor/katex/LICENSE && node scripts/vendor-katex-banner.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "ts-prune": "^0.10.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-store": "^2",
    "katex": "^0.17.0"
  }
}
